<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <UI>
      <Dialog Id="TerminalConfigDlg" Width="370" Height="270" Title="Terminal Configuration">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Terminal Configuration" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="Configure the terminal executable for orchestration" />
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!-- Terminal Executable Path -->
        <Control Id="TerminalLabel" Type="Text" X="20" Y="60" Width="290" Height="10" NoPrefix="yes" Text="Terminal Executable Path:" />
        <Control Id="TerminalExecutableEdit" Type="Edit" X="20" Y="72" Width="250" Height="18" Property="TERMINAL_EXECUTABLE" />
        <Control Id="BrowseTerminal" Type="PushButton" X="275" Y="72" Width="75" Height="18" Text="Browse...">
          <Publish Event="DoAction" Value="WixUIBrowseTerminal">1</Publish>
        </Control>

        <Control Id="TerminalHint" Type="Text" X="20" Y="95" Width="330" Height="30" NoPrefix="yes" Text="Examples:\nC:\Windows\System32\cmd.exe\nC:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe\nC:\scripts\claude_agent.bat" />

        <!-- Working Directory -->
        <Control Id="WorkDirLabel" Type="Text" X="20" Y="130" Width="290" Height="10" NoPrefix="yes" Text="Terminal Working Directory:" />
        <Control Id="WorkDirEdit" Type="Edit" X="20" Y="142" Width="250" Height="18" Property="TERMINAL_WORKING_DIR" />
        <Control Id="BrowseWorkDir" Type="PushButton" X="275" Y="142" Width="75" Height="18" Text="Browse...">
          <Publish Event="DoAction" Value="WixUIBrowseWorkDir">1</Publish>
        </Control>

        <!-- Bottom buttons -->
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>
    </UI>
  </Fragment>
</Wix>
