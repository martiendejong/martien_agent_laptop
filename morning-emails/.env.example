# Morning Email Briefing Configuration

# Gmail OAuth Credentials Path
# Download from Google Cloud Console: https://console.cloud.google.com/
GMAIL_CREDENTIALS_PATH=C:\path\to\credentials.json
GMAIL_TOKEN_PATH=C:\scripts\morning-emails\token.json

# Optional: Custom OAuth paths (if using Gmail MCP)
# GMAIL_CREDENTIALS_PATH=C:\path\to\gmail-mcp\credentials.json
# GMAIL_TOKEN_PATH=C:\path\to\gmail-mcp\token.json
